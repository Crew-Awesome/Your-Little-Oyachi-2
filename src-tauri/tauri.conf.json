{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../app/index.html",
    "distDir": "../app"
  },
  "package": {
    "productName": "YourLittleOyachi2",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false
    },
    "bundle": {
      "active": true,
      "identifier": "com.immalloy.yourlittleoyachi2",
      "targets": [
        "app",
        "appimage",
        "nsis"
      ]
    },
    "windows": [
      {
        "title": "Your Little Oyachi 2",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
